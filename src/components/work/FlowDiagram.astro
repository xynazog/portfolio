---
/**
 * Reusable scroll-linked SVG flow diagram. Linear vertical chain of
 * nodes with edges that draw in as the user scrolls past them.
 *
 * Geometry assumes a linear top→bottom flow (each edge's `from` is
 * above its `to`). Branching is not supported — extend later if needed.
 */

export interface FlowNode {
  id: string;
  label: string;
  sublabel?: string;
}

export interface FlowEdge {
  from: string;
  to: string;
  label?: string;
}

interface Props {
  nodes: FlowNode[];
  edges: FlowEdge[];
  caption?: string;
  ariaLabel?: string;
}

const { nodes, edges, caption, ariaLabel = "flow diagram" } = Astro.props;

const VB_W = 400;
const NODE_W = 360;
const NODE_H = 64;
const NODE_X = (VB_W - NODE_W) / 2;
const NODE_CENTER_X = VB_W / 2;
const GAP = 84;
const PAD_TOP = 12;
const PAD_BOTTOM = 12;
const ARROW_INSET = 6;

const nodeYs = nodes.map((_, i) => PAD_TOP + i * (NODE_H + GAP));
const VB_H =
  PAD_TOP + nodes.length * NODE_H + (nodes.length - 1) * GAP + PAD_BOTTOM;

const nodeIndexById = new Map(nodes.map((n, i) => [n.id, i] as const));
const edgeGeoms = edges.map((e) => {
  const fromIdx = nodeIndexById.get(e.from);
  const toIdx = nodeIndexById.get(e.to);
  if (fromIdx === undefined || toIdx === undefined) {
    throw new Error(
      `FlowDiagram: edge ${e.from}->${e.to} references unknown node id`
    );
  }
  if (fromIdx >= toIdx) {
    throw new Error(
      `FlowDiagram: edge ${e.from}->${e.to} is not forward; component assumes linear top→bottom flow`
    );
  }
  const y1 = nodeYs[fromIdx] + NODE_H;
  const y2 = nodeYs[toIdx] - ARROW_INSET;
  const midY = (y1 + y2) / 2;
  return { y1, y2, midY, label: e.label };
});
---

<figure class="flow-diagram-wrap">
  {caption && (
    <figcaption class="flow-diagram-caption font-mono text-mono-sm">
      {caption}
    </figcaption>
  )}
  <svg
    class="flow-diagram"
    viewBox={`0 0 ${VB_W} ${VB_H}`}
    width="100%"
    role="img"
    aria-label={ariaLabel}
    preserveAspectRatio="xMidYMin meet"
  >
    {edgeGeoms.map((g, i) => (
      <line
        class="flow-edge"
        data-edge-index={i}
        x1={NODE_CENTER_X}
        y1={g.y1}
        x2={NODE_CENTER_X}
        y2={g.y2}
        stroke="var(--color-accent)"
        stroke-width="1.5"
        stroke-linecap="round"
        pathLength="1"
        style="stroke-dasharray: 1; stroke-dashoffset: 1;"
      />
    ))}
    {edgeGeoms.map((g, i) => (
      <polygon
        class="flow-arrow"
        data-edge-index={i}
        points={`${NODE_CENTER_X - 4},${g.y2 - 1} ${NODE_CENTER_X + 4},${g.y2 - 1} ${NODE_CENTER_X},${g.y2 + 4}`}
        fill="var(--color-accent)"
        style="opacity: 0;"
      />
    ))}
    {edgeGeoms.map((g, i) =>
      g.label ? (
        <text
          class="flow-edge-label"
          data-edge-index={i}
          x={NODE_CENTER_X}
          y={g.midY}
          text-anchor="middle"
          dominant-baseline="middle"
          style="opacity: 0;"
        >
          {g.label}
        </text>
      ) : null
    )}
    {nodes.map((n, i) => (
      <g class="flow-node" data-node-index={i} style="opacity: 0.35;">
        <rect
          x={NODE_X}
          y={nodeYs[i]}
          width={NODE_W}
          height={NODE_H}
          rx="6"
          fill="var(--color-bg-elev)"
          stroke="var(--color-border)"
          stroke-width="1"
        />
        <text class="flow-node-label" x={NODE_X + 18} y={nodeYs[i] + 26}>
          {n.label}
        </text>
        {n.sublabel && (
          <text
            class="flow-node-sublabel"
            x={NODE_X + 18}
            y={nodeYs[i] + 46}
          >
            {n.sublabel}
          </text>
        )}
      </g>
    ))}
  </svg>
</figure>

<style>
  .flow-diagram-wrap {
    margin: 0;
    max-width: 440px;
    margin-inline: auto;
    padding-block: clamp(0.5rem, 2vw, 1.5rem);
  }
  .flow-diagram-caption {
    color: var(--color-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .flow-diagram {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* SVG text styles. SVG elements honor CSS `font-family` and `fill`. */
  .flow-node-label {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    fill: var(--color-fg-hi);
  }
  .flow-node-sublabel {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--color-muted);
    letter-spacing: 0.02em;
  }
  .flow-edge-label {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--color-muted);
    letter-spacing: 0.02em;
    /* Knock the accent edge line out from behind the label text so
       the line doesn't strike through it. Stroke is drawn first, fill
       on top. */
    paint-order: stroke;
    stroke: var(--color-bg);
    stroke-width: 6px;
    stroke-linejoin: round;
  }

  /* Mobile: the SVG already scales via width:100%; we just want a
     slightly tighter container and bigger relative text. */
  @media (max-width: 640px) {
    .flow-diagram-wrap {
      max-width: 100%;
    }
  }
</style>

<script>
  // Scroll-linked draw-in for each FlowDiagram on the page.
  // Honours prefers-reduced-motion (renders final state immediately).
  // Reattaches after Astro View Transitions navigation.

  function clamp(v: number, lo: number, hi: number): number {
    return v < lo ? lo : v > hi ? hi : v;
  }

  function initFlowDiagrams() {
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

    document.querySelectorAll<SVGSVGElement>(".flow-diagram").forEach((svg) => {
      if (svg.dataset.flowInit === "true") return;
      svg.dataset.flowInit = "true";

      const edges = svg.querySelectorAll<SVGLineElement>(".flow-edge");
      const arrows = svg.querySelectorAll<SVGPolygonElement>(".flow-arrow");
      const labels = svg.querySelectorAll<SVGTextElement>(".flow-edge-label");
      const nodes = svg.querySelectorAll<SVGGElement>(".flow-node");
      const N = edges.length;

      if (reduced || N === 0) {
        edges.forEach((e) => {
          e.style.strokeDashoffset = "0";
        });
        arrows.forEach((a) => {
          a.style.opacity = "1";
        });
        labels.forEach((l) => {
          l.style.opacity = "1";
        });
        nodes.forEach((n) => {
          n.style.opacity = "1";
        });
        return;
      }

      let ticking = false;
      const update = () => {
        ticking = false;
        const rect = svg.getBoundingClientRect();
        const vh = window.innerHeight;
        // Progress window keyed on the svg's vertical center crossing the
        // viewport — adapts cleanly whether the diagram is shorter or taller
        // than the viewport. progress is 0 when the center sits at the
        // viewport bottom, 1 when it sits at 40% from the top. This means
        // each edge animates while its band of the diagram is on-screen.
        const center = rect.top + rect.height / 2;
        const start = vh;
        const end = vh * 0.4;
        const denom = start - end || 1;
        const progress = clamp((start - center) / denom, 0, 1);

        edges.forEach((edge, i) => {
          const localP = clamp(progress * N - i, 0, 1);
          edge.style.strokeDashoffset = String(1 - localP);
        });
        arrows.forEach((arrow, i) => {
          const localP = clamp(progress * N - i, 0, 1);
          arrow.style.opacity = String(
            localP > 0.85 ? (localP - 0.85) / 0.15 : 0
          );
        });
        labels.forEach((label) => {
          const i = Number(label.dataset.edgeIndex);
          const localP = clamp(progress * N - i, 0, 1);
          label.style.opacity = String(
            clamp((localP - 0.1) / 0.3, 0, 1)
          );
        });
        nodes.forEach((node, i) => {
          const lit =
            i === 0
              ? progress > 0
                ? 1
                : 0
              : clamp(progress * N - (i - 1), 0, 1);
          node.style.opacity = String(0.35 + 0.65 * lit);
        });
      };

      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      };

      let scrollAttached = false;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting && !scrollAttached) {
              window.addEventListener("scroll", onScroll, { passive: true });
              window.addEventListener("resize", onScroll);
              scrollAttached = true;
              update();
            } else if (!e.isIntersecting && scrollAttached) {
              window.removeEventListener("scroll", onScroll);
              window.removeEventListener("resize", onScroll);
              scrollAttached = false;
            }
          });
        },
        { rootMargin: "200px 0px 200px 0px" }
      );
      io.observe(svg);
      update();
    });
  }

  initFlowDiagrams();
  document.addEventListener("astro:after-swap", initFlowDiagrams);
</script>
