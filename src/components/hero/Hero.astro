---
import StackedHeadline, { type StackedLine } from "./StackedHeadline.astro";

const lines: StackedLine[] = [
  {
    text: "I lead the team building",
    size: "display-xl",
    family: "display",
    weight: 600,
    color: "fg-hi",
  },
  {
    text: "the platforms and products other engineers depend on.",
    size: "display-lg",
    family: "display",
    weight: 420,
    color: "fg",
    highlights: ["platforms", "products"],
  },
];
---

<section class="hero">
  <div class="container-page hero__inner">
    <p
      class="hero__eyebrow font-mono text-mono-sm"
      style="--stack-delay: 0ms"
    >
      <span class="hero__dot" aria-hidden="true"></span>
      engineering manager · identity · AI-first
    </p>

    <StackedHeadline lines={lines} />

    <div class="hero__ctas" style="--stack-delay: 360ms">
      <a class="hero__cta hero__cta--primary font-mono text-mono-sm" href="#work">
        view work
      </a>
      <a
        class="hero__cta font-mono text-mono-sm"
        href="/resume.pdf"
        target="_blank"
        rel="noopener"
      >
        download resume <span aria-hidden="true">↗</span>
      </a>
    </div>

    {/* Impact strip — each stat sourced from a case study in src/lib/work.ts.
        Update both places intentionally when the underlying numbers shift. */}
    <p class="hero__impact font-mono text-mono-sm" style="--stack-delay: 440ms">
      <span>7 yrs at splunk</span>
      <span aria-hidden="true" class="hero__impact-sep">·</span>
      <span>10 engineers led</span>
      <span aria-hidden="true" class="hero__impact-sep">·</span>
      <span>$159M+ TCV influenced</span>
      <span aria-hidden="true" class="hero__impact-sep">·</span>
      <span>60% query latency cut</span>
    </p>

    <p class="hero__location-trail font-mono text-mono-sm" style="--stack-delay: 600ms">
      <span class="hero__trail-prefix">↓</span>
      <span>more below</span>
    </p>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(4rem, 8vw, 7rem);
    padding-bottom: clamp(5rem, 10vw, 9rem);
    position: relative;
  }
  .hero__inner {
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  .hero__eyebrow {
    color: var(--color-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    opacity: 0;
    animation: hero-eyebrow-in 600ms var(--ease-out-soft) forwards;
    animation-delay: 60ms;
  }
  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow:
      0 0 0 4px color-mix(in oklab, var(--color-accent) 12%, transparent);
    display: inline-block;
    /* Soft radar ping — gentle, branded. Loops every 2.4s. */
    animation: hero-dot-pulse 2.4s ease-out infinite;
  }
  @keyframes hero-dot-pulse {
    0% {
      box-shadow:
        0 0 0 4px  color-mix(in oklab, var(--color-accent) 12%, transparent),
        0 0 0 4px  color-mix(in oklab, var(--color-accent) 45%, transparent);
    }
    70% {
      box-shadow:
        0 0 0 4px  color-mix(in oklab, var(--color-accent) 12%, transparent),
        0 0 0 14px color-mix(in oklab, var(--color-accent) 0%,  transparent);
    }
    100% {
      box-shadow:
        0 0 0 4px  color-mix(in oklab, var(--color-accent) 12%, transparent),
        0 0 0 14px color-mix(in oklab, var(--color-accent) 0%,  transparent);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__dot { animation: none; }
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin-top: clamp(1.25rem, 2.5vw, 2rem);
    opacity: 0;
    animation: hero-eyebrow-in 600ms var(--ease-out-soft) forwards;
    animation-delay: var(--stack-delay, 360ms);
  }
  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.1rem;
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    border-radius: 2px;
    transition:
      background-color 200ms var(--ease-out-soft),
      border-color 200ms var(--ease-out-soft),
      color 200ms var(--ease-out-soft);
  }
  .hero__cta:hover,
  .hero__cta:focus-visible {
    background: var(--color-bg-elev);
    border-color: var(--color-muted);
  }
  .hero__cta--primary {
    border-color: var(--color-accent);
    color: var(--color-fg-hi);
  }
  .hero__cta--primary:hover,
  .hero__cta--primary:focus-visible {
    background: color-mix(in oklab, var(--color-accent) 14%, transparent);
    border-color: var(--color-accent-hi);
  }

  .hero__impact {
    color: var(--color-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.65rem;
    margin: 0;
    opacity: 0;
    animation: hero-eyebrow-in 600ms var(--ease-out-soft) forwards;
    animation-delay: var(--stack-delay, 440ms);
  }
  .hero__impact-sep {
    color: var(--color-subtle);
  }

  .hero__location-trail {
    color: var(--color-subtle);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    opacity: 0;
    animation: hero-eyebrow-in 600ms var(--ease-out-soft) forwards;
    animation-delay: var(--stack-delay, 600ms);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__ctas, .hero__impact { opacity: 1; animation: none; }
  }
  .hero__trail-prefix {
    color: var(--color-muted);
  }
  @keyframes hero-eyebrow-in {
    to { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__eyebrow, .hero__location-trail { opacity: 1; animation: none; }
  }
</style>
