---
/**
 * Colophon + minimal footer. Per Keya: a literal "Set in [typeface]" line.
 * The .well-known/contact.json link makes the JSON joke from Contact.astro
 * round-trip — same data, served as application/json.
 */

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-page footer__inner">
    <p class="footer__colophon font-mono text-mono-sm">
      Set in
      <a href="https://vercel.com/font" target="_blank" rel="noreferrer">Geist</a>
      &amp;
      <a
        href="https://fonts.adobe.com/fonts/source-serif"
        target="_blank"
        rel="noreferrer">Source&nbsp;Serif&nbsp;4</a>.
      Built with
      <a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a>.
      Hosted on
      <a href="https://pages.cloudflare.com" target="_blank" rel="noreferrer">Cloudflare</a>.
    </p>

    <div class="footer__row">
      <p class="footer__copy font-mono text-mono-sm">© {year} Ankit Bhagat</p>
      <a class="footer__endpoint font-mono text-mono-sm" href="/.well-known/contact.json">
        GET /.well-known/contact.json &rarr;
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: clamp(6rem, 12vw, 10rem);
  }
  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-block: 3rem;
  }
  .footer__colophon {
    color: var(--color-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    max-width: 60ch;
    line-height: 1.7;
  }
  .footer__colophon a {
    color: var(--color-fg);
    border-bottom: 1px dotted var(--color-subtle);
    transition: color 160ms var(--ease-out-soft), border-color 160ms var(--ease-out-soft);
  }
  .footer__colophon a:hover,
  .footer__colophon a:focus-visible {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .footer__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--color-border);
  }
  .footer__copy {
    color: var(--color-subtle);
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .footer__endpoint {
    color: var(--color-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    transition: color 160ms var(--ease-out-soft);
  }
  .footer__endpoint:hover,
  .footer__endpoint:focus-visible { color: var(--color-accent); }
</style>
