---
/**
 * Opening thesis. Sits between Hero and About — picks up the italic
 * serif moment from the hero's third line and turns it into a
 * positioning statement.
 *
 * "Both matter." renders as its own quiet beat in roman so it lands
 * harder than another italic phrase would.
 */
---

<section class="opener" aria-label="opening thesis">
  <div class="container-page opener__inner">
    <p class="opener__line font-serif scroll-reveal-text">
      Software is two products: the one users see, and the one the next engineer maintains.
    </p>
    <p class="opener__beat font-serif scroll-reveal-text">Both matter.</p>
  </div>
</section>

<style>
  .opener {
    padding-block: clamp(4rem, 8vw, 7rem);
  }
  .opener__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.5rem);
    text-align: center;
  }
  .opener__line {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.625rem, 3.4vw, 2.75rem);
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--color-fg-hi);
    max-width: 30ch;
    text-wrap: balance;
    margin: 0;
  }
  .opener__beat {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-accent-hi);   /* AA at this size */
    margin: 0;
  }
</style>
