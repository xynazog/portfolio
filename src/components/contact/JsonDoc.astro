---
import { contact, displayEndpoint } from "../../lib/contact";

/**
 * The signature handcrafted moment. The Contact section IS a syntax-
 * highlighted JSON document. Each URL/email value is a real link.
 * Companion endpoint lives at /.well-known/contact.json — same data,
 * served as application/json.
 *
 * Rendered as styled lines (not <pre>) so each value can have hover
 * affordances without fighting whitespace.
 */

const c = contact;
---

<div class="json-doc">
  <header class="json-doc__head">
    <span class="json-doc__path font-mono text-mono-sm">
      ~/.well-known/contact.json
    </span>
    <span class="json-doc__status font-mono text-mono-sm">
      <span class="json-doc__status-dot" aria-hidden="true"></span>
      200 ok
    </span>
  </header>

  <div class="json-doc__body font-mono">
    <div class="line"><span class="p">{`{`}</span></div>

    <div class="line" style="--i: 1">
      <span class="k">"issuer"</span><span class="p">:</span>
      <a class="s s--link" href={c.issuer} target="_blank" rel="noreferrer">"{c.issuer}"</a><span class="p">,</span>
    </div>

    <div class="line" style="--i: 1">
      <span class="k">"subject"</span><span class="p">: {`{`}</span>
    </div>
    <div class="line" style="--i: 2">
      <span class="k">"name"</span><span class="p">:</span> <span class="s">"{c.subject.name}"</span><span class="p">,</span>
    </div>
    <div class="line" style="--i: 2">
      <span class="k">"role"</span><span class="p">:</span> <span class="s">"{c.subject.role}"</span><span class="p">,</span>
    </div>
    <div class="line" style="--i: 2">
      <span class="k">"location"</span><span class="p">:</span> <span class="s">"{c.subject.location}"</span>
    </div>
    <div class="line" style="--i: 1"><span class="p">{`},`}</span></div>

    <div class="line" style="--i: 1">
      <span class="k">"endpoints"</span><span class="p">: {`{`}</span>
    </div>
    <div class="line" style="--i: 2">
      <span class="k">"email"</span><span class="p">:</span>
      <a class="s s--link" href={c.endpoints.email}>"{displayEndpoint(c.endpoints.email)}"</a><span class="p">,</span>
    </div>
    <div class="line" style="--i: 2">
      <span class="k">"linkedin"</span><span class="p">:</span>
      <a class="s s--link" href={c.endpoints.linkedin} target="_blank" rel="noreferrer">"{c.endpoints.linkedin}"</a><span class="p">,</span>
    </div>
    <div class="line" style="--i: 2">
      <span class="k">"github"</span><span class="p">:</span>
      <a class="s s--link" href={c.endpoints.github} target="_blank" rel="noreferrer">"{c.endpoints.github}"</a><span class="p">,</span>
    </div>
    <div class="line" style="--i: 2">
      <span class="k">"x"</span><span class="p">:</span>
      <a class="s s--link" href={c.endpoints.x} target="_blank" rel="noreferrer">"{c.endpoints.x}"</a>
    </div>
    <div class="line" style="--i: 1"><span class="p">{`},`}</span></div>

    <div class="line" style="--i: 1">
      <span class="k">"scopes_supported"</span><span class="p">:</span> <span class="p">[</span>{c.scopes_supported.map((s, i) => (
        <><span class="s">"{s}"</span>{i < c.scopes_supported.length - 1 && <span class="p">, </span>}</>
      ))}<span class="p">],</span>
    </div>

    <div class="line" style="--i: 1">
      <span class="k">"audience"</span><span class="p">:</span> <span class="p">[</span>{c.audience.map((s, i) => (
        <><span class="s">"{s}"</span>{i < c.audience.length - 1 && <span class="p">, </span>}</>
      ))}<span class="p">],</span>
    </div>

    <div class="line" style="--i: 1">
      <span class="k">"response_time"</span><span class="p">:</span> <span class="s">"{c.response_time}"</span>
    </div>

    <div class="line"><span class="p">{`}`}</span></div>
  </div>
</div>

<style>
  .json-doc {
    background: var(--color-bg-elev);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    max-width: 60ch;
    overflow: hidden;
    box-shadow:
      0 1px 0 color-mix(in oklab, white 4%, transparent) inset,
      0 30px 60px -30px rgba(0, 0, 0, 0.6);
  }
  .json-doc__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-bg) 60%, var(--color-bg-elev));
    color: var(--color-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .json-doc__path::before {
    content: "● ";
    color: var(--color-accent);
  }
  .json-doc__status {
    color: var(--color-accent-hi);   /* 6.65:1 — passes AA at small size */
    border: 1px solid color-mix(in oklab, var(--color-accent-hi) 35%, transparent);
    padding: 0.05em 0.6em;
    border-radius: 999px;
    font-size: 0.7rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
  }
  /* Live-status idiom — true signal green, intentionally outside the warm
     palette because the green=alive convention is universal. The ripple is
     a single box-shadow expanding outward, restarted every cycle. */
  .json-doc__status-dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.55);
    animation: status-dot-pulse 1.8s var(--ease-out-soft) infinite;
    flex-shrink: 0;
  }
  @keyframes status-dot-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
    70%  { box-shadow: 0 0 0 7px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }
  .json-doc__body {
    padding: 1.25rem 1.25rem 1.25rem 1.25rem;
    font-size: 0.8125rem;
    line-height: 1.7;
    overflow-x: auto;
  }
  .line {
    padding-left: calc(var(--i, 0) * 1.4rem);
    white-space: nowrap;
  }
  .k { color: var(--color-muted); }      /* keys */
  .s { color: var(--color-fg); }          /* strings */
  .p { color: var(--color-subtle); }      /* punctuation */
  .s--link {
    color: var(--color-accent-hi);   /* 6.65:1 — passes AA at body/mono size */
    text-decoration: none;
    border-bottom: 1px dashed color-mix(in oklab, var(--color-accent-hi) 40%, transparent);
    transition: color 160ms var(--ease-out-soft), border-color 160ms var(--ease-out-soft);
  }
  .s--link:hover,
  .s--link:focus-visible {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* Typewriter reveal — chars wrapped in .tw spans by JS before the
     animation runs. Default: visible (so no-JS users and post-animation
     state both render normally). While [data-typing] is set on the body,
     un-revealed chars are hidden — layout is preserved because the
     spans still occupy their box. */
  .tw {
    opacity: 1;
    transition: opacity 80ms var(--ease-out-soft);
  }
  .json-doc__body[data-typing="true"] .tw { opacity: 0; }
  .json-doc__body[data-typing="true"] .tw.tw--shown { opacity: 1; }
</style>

<script>
  // Typewriter: reveal the JSON body character-by-character the first
  // time it scrolls into the viewport. Wraps each char in a span ONCE
  // (no per-tick DOM rewrite), then toggles a class per char. Honours
  // prefers-reduced-motion and sessionStorage (first-impression only).
  // Reattaches after Astro View Transitions navigation.

  const SESSION_KEY = "contact-typewriter-played";
  const TOTAL_MS = 1800;

  function collectTextNodes(node: Node, out: Text[]) {
    if (node.nodeType === Node.TEXT_NODE) {
      out.push(node as Text);
      return;
    }
    if (node.nodeType === Node.ELEMENT_NODE) {
      node.childNodes.forEach((c) => collectTextNodes(c, out));
    }
  }

  function wrapTextNode(textNode: Text, accum: HTMLSpanElement[]) {
    const raw = textNode.nodeValue ?? "";
    if (!raw) return;
    // Mimic CSS whitespace collapsing so we don't render literal indentation.
    const whitespaceOnly = /^\s+$/.test(raw);
    let text = raw;
    if (whitespaceOnly) {
      const hasPrev = textNode.previousSibling !== null;
      const hasNext = textNode.nextSibling !== null;
      if (!hasPrev || !hasNext) {
        textNode.remove();
        return;
      }
      text = " ";
    } else {
      text = raw.replace(/\s+/g, " ");
    }
    const frag = document.createDocumentFragment();
    for (const ch of text) {
      const span = document.createElement("span");
      span.className = "tw";
      span.textContent = ch;
      frag.appendChild(span);
      accum.push(span);
    }
    textNode.parentNode!.replaceChild(frag, textNode);
  }

  function animate(chars: HTMLSpanElement[], body: HTMLElement) {
    sessionStorage.setItem(SESSION_KEY, "true");
    const total = chars.length;
    if (total === 0) {
      body.removeAttribute("data-typing");
      return;
    }
    const baseInterval = TOTAL_MS / total;
    let i = 0;
    const tick = () => {
      if (i >= total) {
        body.removeAttribute("data-typing");
        return;
      }
      chars[i].classList.add("tw--shown");
      i++;
      const jitter = Math.random() * 20 - 10; // ±10ms
      const delay = Math.max(1, baseInterval + jitter);
      setTimeout(tick, delay);
    };
    tick();
  }

  function setupTypewriter() {
    const body = document.querySelector<HTMLElement>(".json-doc__body");
    if (!body || body.dataset.twInit === "true") return;
    body.dataset.twInit = "true";

    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const played = sessionStorage.getItem(SESSION_KEY) === "true";
    if (reduce || played) return; // render normally — no wrap, no animation

    const textNodes: Text[] = [];
    collectTextNodes(body, textNodes);
    const chars: HTMLSpanElement[] = [];
    textNodes.forEach((t) => wrapTextNode(t, chars));
    if (chars.length === 0) return;

    body.setAttribute("data-typing", "true");

    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect();
          animate(chars, body);
        }
      },
      { threshold: 0.4 }
    );
    io.observe(body);
  }

  setupTypewriter();
  document.addEventListener("astro:after-swap", setupTypewriter);
</script>
