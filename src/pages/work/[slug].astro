---
import Base from "../../layouts/Base.astro";
import FlowDiagram from "../../components/work/FlowDiagram.astro";
import { caseStudies, type CaseStudy } from "../../lib/work";

export function getStaticPaths() {
  return caseStudies.map((c) => ({
    params: { slug: c.slug },
    props: { study: c },
  }));
}

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
const shippedHeader = study.shippedHeader ?? "What we shipped";
---

<Base title={`${study.title} — Ankit Bhagat`}>
  <article class="container-page section case-study">
    <a class="case-study__back font-mono text-mono-sm" href="/#work">
      &larr; back to selected work
    </a>

    <header class="case-study__header">
      <p class="font-mono text-mono-sm case-study__meta">
        {study.context} — {study.dateRange}
      </p>
      <h1 class="case-study__title font-display">{study.title}</h1>
    </header>

    <div class="case-study__grid">
      <aside class="case-study__rail">
        <dl class="case-study__facts">
          <div>
            <dt class="font-mono text-mono-sm">role</dt>
            <dd>{study.role}</dd>
          </div>
          <div>
            <dt class="font-mono text-mono-sm">scope</dt>
            <dd>{study.scope}</dd>
          </div>
          <div>
            <dt class="font-mono text-mono-sm">team</dt>
            <dd>{study.team}</dd>
          </div>
          <div>
            <dt class="font-mono text-mono-sm">stack</dt>
            <dd>{study.stack}</dd>
          </div>
        </dl>
      </aside>

      <div class="case-study__prose">
        <section>
          <h2>The problem</h2>
          <p>{study.problem}</p>
        </section>
        <section>
          <h2>What I led</h2>
          <ul>
            {study.led.map((item) => <li>{item}</li>)}
          </ul>
        </section>
        <section>
          <h2>{shippedHeader}</h2>
          <ul>
            {study.shipped.map((item) => <li>{item}</li>)}
          </ul>
        </section>
        {study.diagram && (
          <section class="case-study__diagram">
            <FlowDiagram
              nodes={study.diagram.nodes}
              edges={study.diagram.edges}
              caption={study.diagram.caption}
              ariaLabel={`${study.title} — flow diagram`}
            />
          </section>
        )}
        <section>
          <h2>What I'd do differently</h2>
          <p>{study.differently}</p>
        </section>
      </div>
    </div>
  </article>
</Base>

<style>
  .case-study__back {
    display: inline-block;
    color: var(--color-muted);
    margin-bottom: 2.5rem;
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .case-study__back:hover,
  .case-study__back:focus-visible { color: var(--color-accent); }

  .case-study__header {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .case-study__meta {
    color: var(--color-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }
  .case-study__title {
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 540;
    color: var(--color-fg-hi);
    margin: 0;
    text-wrap: balance;
    /* em is in title's own font-size — wide enough for a balanced 2-line wrap,
       narrow enough that a single line won't fit. */
    max-width: 18em;
  }

  .case-study__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
  }
  @media (min-width: 880px) {
    .case-study__grid {
      grid-template-columns: minmax(220px, 280px) minmax(0, 1fr);
    }
  }

  /* Diagram section: constrain to the same reading-width as the bullets
     (62ch matches .case-study__prose li), then center the figure within it
     so the diagram sits visually inside the prose's reading column rather
     than centered against the full grid column. */
  .case-study__diagram {
    display: flex;
    justify-content: center;
    max-width: 62ch;
  }

  .case-study__rail {
    border-left: 1px solid var(--color-border);
    padding-left: clamp(1rem, 2vw, 1.5rem);
    align-self: start;
    position: sticky;
    top: 96px;
  }
  @media (max-width: 880px) {
    .case-study__rail {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
      padding-top: 1.25rem;
      position: static;
    }
  }
  .case-study__facts {
    display: grid;
    gap: 1.25rem;
    margin: 0;
  }
  .case-study__facts > div { display: flex; flex-direction: column; gap: 0.2rem; }
  .case-study__facts dt {
    color: var(--color-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .case-study__facts dd {
    color: var(--color-fg);
    font-family: var(--font-serif);
    margin: 0;
  }

  .case-study__prose section { margin-bottom: clamp(2.25rem, 4vw, 3.5rem); }
  .case-study__prose h2 {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2vw, 1.625rem);
    font-weight: 540;
    letter-spacing: -0.01em;
    color: var(--color-fg-hi);
    margin: 0 0 1rem;
  }
  .case-study__prose p {
    font-family: var(--font-serif);
    font-size: clamp(1.0625rem, 1.2vw, 1.125rem);
    line-height: 1.65;
    max-width: 60ch;
    margin: 0;
    color: var(--color-fg);
  }

  .case-study__prose ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .case-study__prose li {
    font-family: var(--font-serif);
    font-size: clamp(1.0625rem, 1.2vw, 1.125rem);
    line-height: 1.65;
    color: var(--color-fg);
    max-width: 62ch;
    padding-left: 1.1rem;
    position: relative;
  }
  .case-study__prose li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 0.55rem;
    height: 1px;
    background: var(--color-muted);
  }
</style>
