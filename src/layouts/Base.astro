---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import GrainOverlay from "../components/layout/GrainOverlay.astro";
import Nav from "../components/layout/Nav.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ankit Bhagat — Engineering Manager",
  description = "Engineering leader. I build the platforms other engineers depend on — identity, observability, and the AI tooling that's about to become both.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://ankitbhagat.com").toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <ClientRouter />
  </head>
  <body>
    <GrainOverlay />
    <Nav />
    <main id="content">
      <slot />
    </main>
    <Footer />

    <script>
      // Global reveal-on-scroll. Honours prefers-reduced-motion.
      // Re-runs after View Transitions navigation so newly-mounted nodes catch up.
      function attachReveals() {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) {
          document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
            el.dataset.revealed = "true";
          });
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                (e.target as HTMLElement).dataset.revealed = "true";
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.05 }
        );
        document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
          if (el.dataset.revealed !== "true") io.observe(el);
        });
      }
      attachReveals();
      document.addEventListener("astro:after-swap", attachReveals);
    </script>
  </body>
</html>
